        <UserObject label="" plantUmlData="{&quot;data&quot;:&quot;@startuml\n!theme plain\nskinparam componentStyle rectangle\nskinparam backgroundColor white\nskinparam BoxPadding 10\n\ntitle Teknik Diagram Çizimi (FX Loan Inquiry)\n\n&#39; --- AKTÖRLER VE SİSTEM DIŞI BİLEŞENLER ---\nactor \&quot;CLIENT\\n(UI / Other Service)\&quot; as Client #E8E8E8\n\n&#39; --- BİZİM MİKROSERVİSİMİZ ---\npackage \&quot;FXLOANINQUIRY-BE\&quot; #F0F8FF {\n    \n    component \&quot;CONTROLLER\\n(FxLoanInquiryController)\&quot; as Controller #FFFFFF\n    \n    component \&quot;SERVICE\\n(FxLoanInquiryServiceImpl)\&quot; as Service #FFFFFF\n    \n    component \&quot;TOKEN SERVICE\\n(Internal Auth)\&quot; as Token #FFFFFF\n    \n    component \&quot;FEIGN CLIENT\\n(RiskCenterSharingClient)\&quot; as FeignClient #FFFFFF\n}\n\n&#39; --- DIŞ SİSTEMLER (Örnek diyagramdaki gibi DataPower yapısı) ---\ncomponent \&quot;DATA POWER\\n(EXTERNAL API GATEWAY)\&quot; as DataPower #FFFACD\ncomponent \&quot;RISK CENTER / KKB\\n(EXTERNAL SYSTEM)\&quot; as KKB #FFFACD\n\n&#39; --- İLİŞKİLER VE AKIŞ (Oklar) ---\nClient -down-&gt; Controller : \&quot; GET /credit-income-info\\n(taxNumber, userCode)\&quot;\n\nController -down-&gt; Service : \&quot; shareCreditAndIncomeInformation()\&quot;\n\nService -right-&gt; Token : \&quot; 1. getToken(SHARE_SCOPE)\&quot;\nService -down-&gt; FeignClient : \&quot; 2. callRiskCenter(token, refId, request)\\n   (Mapper ile dönüşüm yapılır)\&quot;\n\nFeignClient -down-&gt; DataPower : \&quot; HTTP POST\\n/shareCreditIncome\&quot;\nDataPower -down-&gt; KKB : \&quot; Forward Request\&quot;\n\n@enduml&quot;,&quot;format&quot;:&quot;svg&quot;}" id="FSlXzh2Iog6pQz4APr6w-1">
